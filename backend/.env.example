# Copia este archivo a .env y ajusta los valores
# Para conectar Django local a MySQL en Railway:

# Variables de Railway (cópialas desde el panel de Railway)
MYSQLHOST=containers-us-west-xxx.railway.app
MYSQLPORT=12345
MYSQLUSER=root
MYSQLPASSWORD=tu_contraseña
MYSQLDATABASE=railway

# Opcional: si Railway requiere SSL para conexión externa
# MYSQL_SSL=true
